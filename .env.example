# -----------------------------------------------------------------------------
# ARCHIVO DE EJEMPLO DE VARIABLES DE ENTORNO
# Haz una copia de este archivo, renómbrala a ".env" y pon tus datos reales.
# ¡NUNCA subas el archivo ".env" real a GitHub!
# -----------------------------------------------------------------------------

# URL de conexión a la Base de Datos
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE_DE_DATOS?schema=ESQUEMA
# Sustituye las mayúsculas con tus credenciales de Docker o Postgres local.
DATABASE_URL="postgresql://usuario_example:password_example_123@localhost:5432/nombre_bd_ejemplo?schema=public"

# Secreto para firmar tokens JWT
# Para pruebas locales, cualquier texto largo funciona. En prod, usa un hash real.
JWT_SECRET="pon_aqui_tu_secreto_para_desarrollo_98765"

# Puerto en el que corre la API
PORT=example

# Entorno de Node
NODE_ENV=development